#!/usr/bin/env python3
"""Sync docs/cdn-libraries.md generated sections from checktick_app/cdn_assets.json."""

from __future__ import annotations

import json
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
MANIFEST = ROOT / "checktick_app" / "cdn_assets.json"
DOCS = ROOT / "docs" / "cdn-libraries.md"

TABLE_START = "<!-- CDN_LIBRARIES_TABLE:START -->"
TABLE_END = "<!-- CDN_LIBRARIES_TABLE:END -->"
SRI_START = "<!-- CDN_SRI_HASHES:START -->"
SRI_END = "<!-- CDN_SRI_HASHES:END -->"


def _replace_block(text: str, start_marker: str, end_marker: str, new_content: str) -> str:
    if start_marker not in text or end_marker not in text:
        raise RuntimeError(f"Missing marker block: {start_marker} ... {end_marker}")

    start_index = text.index(start_marker) + len(start_marker)
    end_index = text.index(end_marker)
    return text[:start_index] + "\n" + new_content.rstrip() + "\n" + text[end_index:]


def _render_table(assets: list[dict]) -> str:
    lines = [
        "| Library | Version | File | Purpose |",
        "| ------- | ------- | ---- | ------- |",
    ]
    for asset in assets:
        lines.append(
            f"| {asset['name']} | {asset['version']} | `checktick_app/static/{asset['static_file']}` | {asset.get('purpose', '')} |"
        )
    return "\n".join(lines)


def _render_sri(assets: list[dict]) -> str:
    blocks: list[str] = []
    for asset in assets:
        blocks.append(f"### {asset['name']} {asset['version']}")
        blocks.append("")
        blocks.append("```text")
        blocks.append(asset["sri"])
        blocks.append("```")
        blocks.append("")
    return "\n".join(blocks).rstrip() + "\n"


def main() -> None:
    data = json.loads(MANIFEST.read_text(encoding="utf-8"))
    assets = data.get("assets", [])

    docs = DOCS.read_text(encoding="utf-8")
    docs = _replace_block(docs, TABLE_START, TABLE_END, _render_table(assets))
    docs = _replace_block(docs, SRI_START, SRI_END, _render_sri(assets))

    DOCS.write_text(docs, encoding="utf-8")
    print(f"Synced {DOCS}")


if __name__ == "__main__":
    main()
