#!/bin/bash

# Test runner script for CheckTick
# Runs tests in parallel using pytest-xdist for faster execution
# Usage: ./s/test [OPTIONS]
#   --all         Run all tests (default)
#   --fast        Run tests excluding slow/integration tests
#   --a11y        Run only accessibility tests
#   --no-a11y     Run all tests except accessibility (no Chromium needed)
#   --unit        Run only unit tests (exclude playwright)
#   --host-fallback  Run locally via Poetry if Docker web container is not running
#   --serial      Run tests serially (no parallelization)
#   --coverage    Run with coverage report
#   --help        Show this help message

set -e

# Default options
TEST_SCOPE="all"
PARALLEL=true
COVERAGE=false
HOST_FALLBACK=false
EXTRA_ARGS=()

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --all)
            TEST_SCOPE="all"
            shift
            ;;
        --fast)
            TEST_SCOPE="fast"
            shift
            ;;
        --a11y)
            TEST_SCOPE="a11y"
            shift
            ;;
        --unit)
            TEST_SCOPE="unit"
            shift
            ;;
        --no-a11y)
            TEST_SCOPE="no-a11y"
            shift
            ;;
        --serial)
            PARALLEL=false
            shift
            ;;
        --host-fallback)
            HOST_FALLBACK=true
            shift
            ;;
        --coverage)
            COVERAGE=true
            shift
            ;;
        --help)
            echo "CheckTick Test Runner"
            echo ""
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Test Scope Options:"
            echo "  --all         Run all tests (default)"
            echo "  --fast        Run tests excluding slow markers"
            echo "  --a11y        Run only accessibility tests"
            echo "  --no-a11y     Run all tests except accessibility (no Chromium needed)"
            echo "  --unit        Run unit tests only (exclude playwright)"
            echo ""
            echo "Execution Options:"
            echo "  --serial      Run tests serially (no parallelization)"
            echo "  --host-fallback  Run locally if Docker web container is not running"
            echo "  --coverage    Generate coverage report"
            echo ""
            echo "Examples:"
            echo "  $0                    # Run all tests in parallel"
            echo "  $0 --no-a11y          # Run all tests except accessibility"
            echo "  $0 --no-a11y --host-fallback  # Fallback to local run when web container is down"
            echo "  $0 --a11y             # Run accessibility tests only"
            echo "  $0 --fast --coverage  # Fast tests with coverage"
            echo "  $0 --serial           # Run all tests without xdist"
            exit 0
            ;;
        *)
            # Pass unknown args to pytest
            EXTRA_ARGS+=("$1")
            shift
            ;;
    esac
done

# Build pytest command
PYTEST_CMD=(python -m pytest)

# Add parallelization flag
if [ "$PARALLEL" = true ]; then
    PYTEST_CMD+=(-n auto)
fi

# Add coverage if requested
if [ "$COVERAGE" = true ]; then
    PYTEST_CMD+=(--cov=checktick_app --cov-report=html --cov-report=term)
fi

# Add test scope filters
case $TEST_SCOPE in
    all)
        # Run everything
        ;;
    fast)
        PYTEST_CMD+=(-m "not slow")
        ;;
    a11y)
        PYTEST_CMD+=(tests/test_accessibility.py)
        ;;
    no-a11y)
        PYTEST_CMD+=(--ignore=tests/test_accessibility.py)
        ;;
    unit)
        PYTEST_CMD+=(--ignore=tests/test_accessibility.py)
        ;;
esac

# Add any extra args
if [ ${#EXTRA_ARGS[@]} -gt 0 ]; then
    PYTEST_CMD+=("${EXTRA_ARGS[@]}")
fi

# Determine execution mode
EXEC_PREFIX=()
if docker compose ps --status running --services 2>/dev/null | grep -q '^web$'; then
    EXEC_PREFIX=(docker compose exec web)
else
    if [ "$HOST_FALLBACK" = true ]; then
        if command -v poetry >/dev/null 2>&1; then
            EXEC_PREFIX=(poetry run)
        else
            echo "⚠️  Docker web container is not running and Poetry is not available." >&2
            echo "    Falling back to local Python environment." >&2
        fi
    else
        echo "❌ Docker web container is not running." >&2
        echo "   Start it with: docker compose up -d" >&2
        echo "   Or run tests locally with: $0 --host-fallback [other flags]" >&2
        exit 1
    fi
fi

echo "🧪 Running tests..."
echo "   Command: ${EXEC_PREFIX[*]} ${PYTEST_CMD[*]}"
echo ""

# Run tests
if [ ${#EXEC_PREFIX[@]} -gt 0 ]; then
    "${EXEC_PREFIX[@]}" "${PYTEST_CMD[@]}"
else
    "${PYTEST_CMD[@]}"
fi
