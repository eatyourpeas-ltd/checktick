#!/bin/bash

# Test runner script for CheckTick
# Runs tests in parallel using pytest-xdist for faster execution
# Usage: ./s/test [OPTIONS]
#   --all         Run all tests (default)
#   --fast        Run tests excluding slow/integration tests
#   --a11y-only   Run only accessibility tests in the local Chromium container
#   --a11y        Alias for --a11y-only
#   --no-a11y     Run all tests except accessibility (no Chromium needed)
#   --unit        Run only unit tests (exclude playwright)
#   --host-fallback  Run locally via Poetry instead of Docker (skip container entirely)
#   --serial      Run tests serially (no parallelization)
#   --coverage    Run with coverage report
#   --help        Show this help message
#
# Docker behaviour:
#   If the web container is already running, tests run inside it.
#   If it is not running, the script will start it (docker compose up -d)
#   and wait for it to become healthy before running tests.
#   Pass --host-fallback to skip Docker entirely and run via Poetry.
#   Accessibility-only tests use docker-compose.a11y.yml and run in a
#   Chromium-capable test container instead of the web container.

set -e

# Default options
TEST_SCOPE="all"
PARALLEL=true
COVERAGE=false
HOST_FALLBACK=false
EXTRA_ARGS=()

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --all)
            TEST_SCOPE="all"
            shift
            ;;
        --fast)
            TEST_SCOPE="fast"
            shift
            ;;
        --a11y|--a11y-only)
            TEST_SCOPE="a11y-only"
            shift
            ;;
        --unit)
            TEST_SCOPE="unit"
            shift
            ;;
        --no-a11y)
            TEST_SCOPE="no-a11y"
            shift
            ;;
        --serial)
            PARALLEL=false
            shift
            ;;
        --host-fallback)
            HOST_FALLBACK=true
            shift
            ;;
        --coverage)
            COVERAGE=true
            shift
            ;;
        --help)
            echo "CheckTick Test Runner"
            echo ""
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Test Scope Options:"
            echo "  --all         Run all tests (default)"
            echo "  --fast        Run tests excluding slow markers"
            echo "  --a11y-only   Run only accessibility tests in the local Chromium container"
            echo "  --a11y        Alias for --a11y-only"
            echo "  --no-a11y     Run all tests except accessibility (no Chromium needed)"
            echo "  --unit        Run unit tests only (exclude playwright)"
            echo ""
            echo "Execution Options:"
            echo "  --serial      Run tests serially (no parallelization)"
            echo "  --host-fallback  Run locally via Poetry instead of Docker (requires local DB on port 5432)"
            echo "  --coverage    Generate coverage report"
            echo ""
            echo "Examples:"
            echo "  $0                    # Run all tests (starts Docker if needed)"
            echo "  $0 --no-a11y          # Run all tests except accessibility"
            echo "  $0 --no-a11y --host-fallback  # Run locally via Poetry (no Docker)"
            echo "  $0 --a11y-only        # Run accessibility tests only in the Chromium container"
            echo "  $0 --fast --coverage  # Fast tests with coverage"
            echo "  $0 --serial           # Run all tests without xdist"
            exit 0
            ;;
        *)
            # Pass unknown args to pytest
            EXTRA_ARGS+=("$1")
            shift
            ;;
    esac
done

# Build pytest command
PYTEST_CMD=(python -m pytest)

# Add parallelization flag
if [ "$PARALLEL" = true ]; then
    PYTEST_CMD+=(-n auto)
fi

# Add coverage if requested
if [ "$COVERAGE" = true ]; then
    PYTEST_CMD+=(--cov=checktick_app --cov-report=html --cov-report=term)
fi

# Add test scope filters
case $TEST_SCOPE in
    all)
        # Run everything
        ;;
    fast)
        PYTEST_CMD+=(-m "not slow")
        ;;
    a11y-only)
        PYTEST_CMD+=(tests/test_accessibility.py -v)
        ;;
    no-a11y)
        PYTEST_CMD+=(--ignore=tests/test_accessibility.py)
        ;;
    unit)
        PYTEST_CMD+=(--ignore=tests/test_accessibility.py)
        ;;
esac

# Add any extra args
if [ ${#EXTRA_ARGS[@]} -gt 0 ]; then
    PYTEST_CMD+=("${EXTRA_ARGS[@]}")
fi

# Accessibility tests need Chromium, which is intentionally not installed in the
# normal web container. Run them in the dedicated local a11y test service unless
# the caller explicitly requests --host-fallback.
if [ "$TEST_SCOPE" = "a11y-only" ] && [ "$HOST_FALLBACK" = false ]; then
    if ! docker info >/dev/null 2>&1; then
        echo "❌ Docker daemon is not running." >&2
        echo "   Start Docker Desktop, or run: $0 --a11y-only --host-fallback [other flags]" >&2
        exit 1
    fi

    printf -v PYTEST_COMMAND "%q " "${PYTEST_CMD[@]}"
    A11Y_COMMAND="npm install && npm run build:css && python manage.py migrate --noinput && ${PYTEST_COMMAND}"
    COMPOSE_CMD=(docker compose -f docker-compose.yml -f docker-compose.a11y.yml)

    echo "🧪 Running accessibility tests in Chromium container..."
    echo "   Command: ${COMPOSE_CMD[*]} run --rm --build a11y sh -lc \"${A11Y_COMMAND}\""
    echo ""

    "${COMPOSE_CMD[@]}" run --rm --build a11y sh -lc "$A11Y_COMMAND"
    exit 0
fi

# Determine execution mode
EXEC_PREFIX=()
if [ "$HOST_FALLBACK" = true ]; then
    # Explicitly requested local run — skip Docker entirely
    if command -v poetry >/dev/null 2>&1; then
        EXEC_PREFIX=(poetry run)
    else
        echo "⚠️  Poetry is not available. Falling back to local Python environment." >&2
    fi
    # Warn early if no local DB is reachable (the DB port is not exposed from Docker)
    if ! nc -z localhost 5432 2>/dev/null; then
        echo "⚠️  No database found at localhost:5432." >&2
        echo "   --host-fallback requires a local PostgreSQL instance running on the host." >&2
        echo "   The Docker database is not exposed to the host — start the web container" >&2
        echo "   and omit --host-fallback to run tests inside Docker instead." >&2
        exit 1
    fi
elif ! docker info >/dev/null 2>&1; then
    echo "❌ Docker daemon is not running." >&2
    echo "   Start Docker Desktop, or run: $0 --host-fallback [other flags]" >&2
    exit 1
elif docker compose ps --status running --services 2>/dev/null | grep -q '^web$'; then
    # Container already up
    if [ -t 0 ]; then
        EXEC_PREFIX=(docker compose exec web)
    else
        EXEC_PREFIX=(docker compose exec -T web)
    fi
else
    # Container not running — try to start it
    if ! command -v docker >/dev/null 2>&1; then
        echo "❌ Docker is not available and --host-fallback was not specified." >&2
        echo "   Install Docker or run: $0 --host-fallback [other flags]" >&2
        exit 1
    fi
    echo "🐳 Web container is not running. Starting it with docker compose up -d ..."
    docker compose up -d
    echo "⏳ Waiting for web container to become healthy ..."
    RETRIES=30
    until docker compose ps --status running --services 2>/dev/null | grep -q '^web$'; do
        RETRIES=$((RETRIES - 1))
        if [ "$RETRIES" -le 0 ]; then
            echo "❌ Web container did not start in time. Check: docker compose logs web" >&2
            exit 1
        fi
        sleep 2
    done
    echo "✅ Web container is ready."
    if [ -t 0 ]; then
        EXEC_PREFIX=(docker compose exec web)
    else
        EXEC_PREFIX=(docker compose exec -T web)
    fi
fi

echo "🧪 Running tests..."
echo "   Command: ${EXEC_PREFIX[*]} ${PYTEST_CMD[*]}"
echo ""

# Run tests
if [ ${#EXEC_PREFIX[@]} -gt 0 ]; then
    "${EXEC_PREFIX[@]}" "${PYTEST_CMD[@]}"
else
    "${PYTEST_CMD[@]}"
fi
