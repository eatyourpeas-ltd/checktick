#!/usr/bin/env bash

# Lint fixer for CheckTick
# Runs Black, Ruff, and isort against the project root with auto-fix behavior
# Prefers the running Docker web container; falls back to `docker compose run`
# if no container is running.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

cd "$REPO_ROOT"

LINT_CMD="poetry run ruff check --fix . && poetry run black . && poetry run isort . && echo '✅ Linting complete'"

if docker compose ps --status running --services 2>/dev/null | grep -q '^web$'; then
  echo "🐳 Running lint in existing web container..."
  docker compose exec web bash -c "$LINT_CMD"
else
  echo "🐳 No running web container found — starting one with docker compose run..."
  docker compose run --rm web bash -c "$LINT_CMD"
fi
