#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
MANIFEST_FILE="$ROOT_DIR/checktick_app/cdn_assets.json"
LOG_FILE="$ROOT_DIR/docs/compliance/infrastructure-technical-change-log.md"
SYNC_DOCS_SCRIPT="$ROOT_DIR/s/sync-cdn-docs"

DRY_RUN=0
ASSUME_YES=0
SELECTED_KEY=""
PIN_VERSION=""
SYNC_ONLY=0

usage() {
  cat <<EOF
Usage: $(basename "$0") [--dry-run] [--yes] [--key <asset_key>] [--version <x.y.z>] [--sync-docs]

Update self-hosted CDN assets using the single source of truth manifest:
  checktick_app/cdn_assets.json

Options:
  --dry-run        Preview actions without writing files
  --yes            Non-interactive mode (required with --key)
  --key <key>      Asset key from manifest (e.g. htmx, sortablejs, axe_core)
  --version <ver>  Override target version (defaults to latest npm version)
  --sync-docs      Only sync docs/cdn-libraries.md from manifest and exit
EOF
  exit 1
}

while [[ ${1-} != "" ]]; do
  case "$1" in
    --dry-run) DRY_RUN=1 ;;
    --yes) ASSUME_YES=1 ;;
    --key)
      shift
      SELECTED_KEY=${1-}
      [[ -n "$SELECTED_KEY" ]] || usage
      ;;
    --version)
      shift
      PIN_VERSION=${1-}
      [[ -n "$PIN_VERSION" ]] || usage
      ;;
    --sync-docs) SYNC_ONLY=1 ;;
    -h|--help) usage ;;
    *)
      echo "Unknown arg: $1"
      usage
      ;;
  esac
  shift
done

manifest_rows() {
  python3 - <<PY
import json
from pathlib import Path
p = Path(r'''$MANIFEST_FILE''')
data = json.loads(p.read_text(encoding='utf-8'))
for i, a in enumerate(data.get('assets', []), start=1):
    print('|'.join([
        str(i),
        a.get('key',''),
        a.get('name',''),
        a.get('npm_package',''),
        a.get('version',''),
        a.get('static_file',''),
        a.get('source_path',''),
    ]))
PY
}

asset_exists() {
  local key=$1
  python3 - <<PY
import json,sys
from pathlib import Path
p = Path(r'''$MANIFEST_FILE''')
data = json.loads(p.read_text(encoding='utf-8'))
keys = {a.get('key') for a in data.get('assets', [])}
sys.exit(0 if '$key' in keys else 1)
PY
}

asset_field() {
  local key=$1
  local field=$2
  python3 - <<PY
import json
from pathlib import Path
p = Path(r'''$MANIFEST_FILE''')
data = json.loads(p.read_text(encoding='utf-8'))
for a in data.get('assets', []):
    if a.get('key') == '$key':
        print(a.get('$field',''))
        break
PY
}

key_for_index() {
  local idx=$1
  python3 - <<PY
import json
from pathlib import Path
p = Path(r'''$MANIFEST_FILE''')
data = json.loads(p.read_text(encoding='utf-8'))
assets = data.get('assets', [])
idx = int('$idx')
if 1 <= idx <= len(assets):
    print(assets[idx-1].get('key',''))
PY
}

update_manifest_entry() {
  local key=$1
  local version=$2
  local sri=$3

  python3 - <<PY
import json
from pathlib import Path
p = Path(r'''$MANIFEST_FILE''')
data = json.loads(p.read_text(encoding='utf-8'))
for a in data.get('assets', []):
    if a.get('key') == '$key':
        a['version'] = '$version'
        a['sri'] = '$sri'
        break
p.write_text(json.dumps(data, indent=2) + '\n', encoding='utf-8')
PY
}

compute_sri() {
  local file=$1
  local b64
  b64=$(openssl dgst -sha384 -binary "$file" | openssl base64 -A)
  echo "sha384-$b64"
}

sync_docs() {
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "Would run: python3 s/sync-cdn-docs"
    return
  fi
  python3 "$SYNC_DOCS_SCRIPT"
}

append_change_log() {
  local pkg=$1
  local old_ver=$2
  local new_ver=$3
  local sri=$4
  local date_str
  date_str=$(date '+%d/%m/%Y')
  local entry="| $date_str | Dr Simon Chapman | Updated self-hosted $pkg ($old_ver -> $new_ver) and regenerated SHA-384 SRI ($sri) | Routine JavaScript dependency maintenance (no CVE remediation referenced) | Dr Serena Haywood (SIRO) | ✅ Active |"

  if [[ $DRY_RUN -eq 1 ]]; then
    echo "Would append to $LOG_FILE:"
    echo "$entry"
    return
  fi

  printf "\n%s\n" "$entry" >> "$LOG_FILE"
  echo "Appended infrastructure change log entry to $LOG_FILE"
}

get_latest_version() {
  local pkg=$1
  npm view "$pkg" version 2>/dev/null || echo "(unknown)"
}

list_deps() {
  printf "%-3s  %-16s  %-20s  %-14s  %s\n" "#" "Key" "Package" "Current" "Latest"
  while IFS='|' read -r idx key _name pkg current _file _src; do
    latest=$(get_latest_version "$pkg")
    printf "%-3s  %-16s  %-20s  %-14s  %s\n" "$idx" "$key" "$pkg" "$current" "$latest"
  done < <(manifest_rows)
}

find_source_in_package() {
  local tmpdir=$1
  local source_path=$2

  if [[ -f "$tmpdir/package/$source_path" ]]; then
    echo "$tmpdir/package/$source_path"
    return
  fi

  local base
  base=$(basename "$source_path")
  local found
  found=$(find "$tmpdir/package" -type f -name "$base" | head -n1 || true)
  if [[ -n "$found" ]]; then
    echo "$found"
    return
  fi

  echo ""
}

select_key() {
  if [[ -n "$SELECTED_KEY" ]]; then
    if ! asset_exists "$SELECTED_KEY"; then
      echo "Unknown --key: $SELECTED_KEY"
      exit 1
    fi
    echo "$SELECTED_KEY"
    return
  fi

  if [[ $ASSUME_YES -eq 1 ]]; then
    echo "--yes without --key is not supported. Provide --key <asset_key>."
    exit 1
  fi

  echo
  read -rp "Enter the number of the dependency to update (or Enter to cancel): " sel
  if [[ -z "$sel" ]]; then
    echo "Cancelled"
    exit 0
  fi
  if ! [[ "$sel" =~ ^[0-9]+$ ]]; then
    echo "Invalid selection"
    exit 1
  fi

  key=$(key_for_index "$sel")
  if [[ -z "$key" ]]; then
    echo "Selection out of range"
    exit 1
  fi
  echo "$key"
}

update_dep() {
  local key=$1

  local name pkg current_ver static_file source_path
  name=$(asset_field "$key" "name")
  pkg=$(asset_field "$key" "npm_package")
  current_ver=$(asset_field "$key" "version")
  static_file=$(asset_field "$key" "static_file")
  source_path=$(asset_field "$key" "source_path")

  if [[ -z "$pkg" || -z "$static_file" || -z "$source_path" ]]; then
    echo "Asset metadata is incomplete for key: $key"
    exit 1
  fi

  local target_ver
  if [[ -n "$PIN_VERSION" ]]; then
    target_ver="$PIN_VERSION"
  else
    target_ver=$(npm view "$pkg" version 2>/dev/null || true)
  fi

  if [[ -z "$target_ver" ]]; then
    echo "Failed to resolve target version for $pkg"
    exit 1
  fi

  local tmpdir
  tmpdir=$(mktemp -d)
  trap "rm -rf '$tmpdir'" EXIT

  echo "Updating $name ($key): $pkg@$target_ver"
  echo "Packing npm artifact..."
  (cd "$tmpdir" && npm pack "$pkg@$target_ver" --silent)

  local tgz
  tgz=$(ls "$tmpdir"/*.tgz | head -n1)
  tar -xzf "$tgz" -C "$tmpdir"

  local src
  src=$(find_source_in_package "$tmpdir" "$source_path")
  if [[ -z "$src" ]]; then
    echo "Could not find source asset '$source_path' in package $pkg@$target_ver"
    find "$tmpdir/package" -maxdepth 4 -type f \( -name '*.js' -o -name '*.css' \) -print
    exit 1
  fi

  local target_path
  target_path="$ROOT_DIR/checktick_app/static/$static_file"

  if [[ $DRY_RUN -eq 1 ]]; then
    local proposed_sri
    proposed_sri=$(compute_sri "$src")
    echo "Would copy: $src -> $target_path"
    echo "Would set manifest version: $current_ver -> $target_ver"
    echo "Would set manifest sri: $proposed_sri"
    sync_docs
    append_change_log "$pkg" "$current_ver" "$target_ver" "$proposed_sri"
    return
  fi

  mkdir -p "$(dirname "$target_path")"
  cp "$src" "$target_path.tmp"
  chmod 0644 "$target_path.tmp"
  mv -f "$target_path.tmp" "$target_path"

  local new_sri
  new_sri=$(compute_sri "$target_path")

  update_manifest_entry "$key" "$target_ver" "$new_sri"
  echo "Updated manifest: $MANIFEST_FILE"

  sync_docs
  append_change_log "$pkg" "$current_ver" "$target_ver" "$new_sri"

  echo "Updated $target_path"
  echo "SRI: $new_sri"
}

if [[ ! -f "$MANIFEST_FILE" ]]; then
  echo "Missing manifest file: $MANIFEST_FILE"
  exit 1
fi

if [[ $SYNC_ONLY -eq 1 ]]; then
  sync_docs
  exit 0
fi

echo "Update CDN assets (manifest source-of-truth)"
echo "Repository root: $ROOT_DIR"
echo "Manifest: $MANIFEST_FILE"
echo

list_deps
key=$(select_key)
update_dep "$key"

echo "Done."
