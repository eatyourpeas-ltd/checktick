#!/bin/bash

# Development environment startup script for CheckTick
# This script starts the local Docker Compose development environment
# Usage: ./s/dev [--code] [--init-vault] [--init-snomed] [--help]
#   --code          Also opens VS Code after starting containers
#   --init-vault    Initialize Vault on first run (creates AppRole, policies, platform key)
#   --init-snomed   Seed the local SNOMED CT database from TRUD (requires TRUD_API_KEY)
#   --help          Show this help message

set -e

OPEN_VSCODE=false
INIT_VAULT=false
INIT_SNOMED=false

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --code)
            OPEN_VSCODE=true
            shift
            ;;
        --init-vault)
            INIT_VAULT=true
            shift
            ;;
        --init-snomed)
            INIT_SNOMED=true
            shift
            ;;
        --help)
            echo "CheckTick Development Environment Startup"
            echo ""
            echo "Usage: $0 [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --code          Also opens VS Code after starting containers"
            echo "  --init-vault    Initialize Vault (run once on first setup)"
            echo "  --init-snomed   Seed the local SNOMED CT database from TRUD"
            echo "  --help          Show this help message"
            echo ""
            echo "Environment Variables:"
            echo "  OPEN_VSCODE=true    Alternative to --code flag"
            echo ""
            echo "First Time Setup:"
            echo "  1. ./s/dev --init-vault"
            echo "     Sets up Vault with AppRole credentials and platform keys."
            echo "     Save the output VAULT_ROLE_ID and VAULT_SECRET_ID to your .env file."
            echo ""
            echo "  2. ./s/dev --init-snomed"
            echo "     Downloads the UK SNOMED CT monolith from TRUD and builds snomed.db."
            echo "     Requires TRUD_API_KEY to be set in your .env file."
            echo "     ⚠️  This process downloads ~1.5 GB and takes several minutes."
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
    esac
done

# Check environment variable as alternative to flag
if [[ "${OPEN_VSCODE}" == "true" ]]; then
    OPEN_VSCODE=true
fi

echo "🚀 Starting CheckTick development environment..."
echo "📦 Using Dockerfile.dev for development setup"

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    echo "❌ Docker is not running. Please start Docker and try again."
    exit 1
fi

# Build and start the development environment
echo "🏗️  Building and starting containers..."
docker compose -f docker-compose.dev.yml up --build -d

# Wait for Vault to be ready
echo "🔐 Waiting for Vault to be ready..."
VAULT_READY=false
for i in {1..60}; do
    if docker compose -f docker-compose.dev.yml exec -T vault wget -q --spider --proxy off "http://127.0.0.1:8200/v1/sys/health?standbyok=true&uninitcode=200" 2>/dev/null; then
        VAULT_READY=true
        break
    fi
    echo -n "."
    sleep 1
done
echo ""

if [[ "$VAULT_READY" == "false" ]]; then
    echo "⚠️  Vault did not start within 60 seconds"
    echo "   Check logs with: docker compose -f docker-compose.dev.yml logs vault"
    exit 1
fi

echo "✅ Vault is running"

# Check if Vault is initialized (first time setup needed)
VAULT_STATUS=$(docker compose -f docker-compose.dev.yml exec -T vault sh -c 'VAULT_ADDR=http://127.0.0.1:8200 vault status -format=json' 2>/dev/null || echo '{"initialized":false,"sealed":true}')
VAULT_INITIALIZED=$(echo "$VAULT_STATUS" | grep -o '"initialized":[^,}]*' | cut -d':' -f2 | tr -d ' ' || true)
VAULT_SEALED=$(echo "$VAULT_STATUS" | grep -o '"sealed":[^,}]*' | cut -d':' -f2 | tr -d ' ' || true)

if [[ "$VAULT_INITIALIZED" != "true" ]]; then
    echo ""
    echo "⚠️  Vault needs initialization (first time setup)"
    echo "   Run: ./s/dev --init-vault"
    echo ""
    echo "   This creates:"
    echo "   - Unseal keys (4 keys, need 3 to unseal)"
    echo "   - Root token for initial setup"
    echo "   - AppRole credentials for CheckTick"
    echo ""

    if [[ "$INIT_VAULT" != "true" ]]; then
        echo "💡 Vault will remain sealed until initialized"
    fi
elif [[ "$INIT_VAULT" == "true" ]]; then
    echo "ℹ️  Vault is already initialized"
    echo "   Skipping initialization - setup has already been run"
    echo ""
    INIT_VAULT=false
fi

# Initialize Vault if requested and not yet done
if [[ "$INIT_VAULT" == "true" ]] && [[ "$VAULT_INITIALIZED" != "true" ]]; then
    echo ""
    echo "🔐 Initializing Vault (first time setup)..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Initialize Vault with Shamir secret sharing
    echo "📝 Initializing Vault with 4 unseal keys (need 3 to unseal)..."
    INIT_OUTPUT=$(docker compose -f docker-compose.dev.yml exec -T vault sh -c 'VAULT_ADDR=http://127.0.0.1:8200 vault operator init -key-shares=4 -key-threshold=3 -format=json')

    # Save output to temp file for easier parsing
    echo "$INIT_OUTPUT" > /tmp/vault_init.json

    # Extract keys and token using Python for reliable JSON parsing
    UNSEAL_KEYS=$(python3 -c "import json; data=json.load(open('/tmp/vault_init.json')); print('\n'.join(data['unseal_keys_b64']))")
    ROOT_TOKEN=$(python3 -c "import json; data=json.load(open('/tmp/vault_init.json')); print(data['root_token'])")

    # Split keys into individual variables
    UNSEAL_KEY_1=$(echo "$UNSEAL_KEYS" | sed -n '1p')
    UNSEAL_KEY_2=$(echo "$UNSEAL_KEYS" | sed -n '2p')
    UNSEAL_KEY_3=$(echo "$UNSEAL_KEYS" | sed -n '3p')
    UNSEAL_KEY_4=$(echo "$UNSEAL_KEYS" | sed -n '4p')

    echo ""
    echo "🔑 Vault Initialized! Save these credentials securely:"
    echo ""
    echo "Unseal Key 1: $UNSEAL_KEY_1"
    echo "Unseal Key 2: $UNSEAL_KEY_2"
    echo "Unseal Key 3: $UNSEAL_KEY_3"
    echo "Unseal Key 4: $UNSEAL_KEY_4"
    echo ""
    echo "Root Token: $ROOT_TOKEN"
    echo ""
    echo "⚠️  IMPORTANT: Store these keys in a password manager NOW!"
    echo "    You need 3 keys to unseal Vault after restart"
    echo ""

    # Unseal Vault
    echo "🔓 Unsealing Vault with 3 keys..."
    docker compose -f docker-compose.dev.yml exec -T vault sh -c "VAULT_ADDR=http://127.0.0.1:8200 vault operator unseal '$UNSEAL_KEY_1'" > /dev/null
    docker compose -f docker-compose.dev.yml exec -T vault sh -c "VAULT_ADDR=http://127.0.0.1:8200 vault operator unseal '$UNSEAL_KEY_2'" > /dev/null
    docker compose -f docker-compose.dev.yml exec -T vault sh -c "VAULT_ADDR=http://127.0.0.1:8200 vault operator unseal '$UNSEAL_KEY_3'" > /dev/null
    echo "✅ Vault unsealed"
    echo ""

    # Clean up temp file
    rm -f /tmp/vault_init.json

    # Run CheckTick setup
    echo "⚙️  Setting up CheckTick Vault configuration..."

    # Check if Python and hvac are available
    if ! command -v python3 &> /dev/null; then
        echo "❌ Python 3 is required to initialize Vault"
        exit 1
    fi

    if ! python3 -c "import hvac" 2>/dev/null; then
        echo "📦 Installing hvac package..."
        pip3 install hvac
    fi

    # Run setup script with root token
    export VAULT_ADDR=http://localhost:8200
    export VAULT_TOKEN=$ROOT_TOKEN
    export VAULT_TLS_VERIFY_SETUP=false

    python3 vault/setup_vault.py

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "✅ Vault initialized successfully!"
    echo ""
    echo "📝 NEXT STEPS - Complete setup in order:"
    echo ""
    echo "1️⃣  Add to your .env file (in the project root):"
    echo ""
    echo "   VAULT_ADDR=http://vault:8200"
    echo "   VAULT_TLS_VERIFY=false"
    echo "   VAULT_ROLE_ID=<copy_from_output_above>"
    echo "   VAULT_SECRET_ID=<copy_from_output_above>"
    echo ""
    echo "2️⃣  Split the custodian component (from output above):"
    echo ""
    echo "   python manage.py split_custodian_component \\"
    echo "     --custodian-component=<paste_hex_from_above>"
    echo ""
    echo "   This creates 4 shares - store them securely:"
    echo "   - Share 1: Your password manager"
    echo "   - Share 2: Backup password manager"
    echo "   - Share 3: Physical secure location"
    echo "   - Share 4: Encrypted cloud backup"
    echo ""
    echo "3️⃣  Restart the development environment:"
    echo ""
    echo "   docker compose -f docker-compose.dev.yml restart web"
    echo ""
    echo "4️⃣  Test the connection:"
    echo ""
    echo "   docker compose -f docker-compose.dev.yml exec web \\"
    echo "     python manage.py test_vault_connection"
    echo ""
    echo "5️⃣  Revoke the root token (security best practice):"
    echo ""
    echo "   docker compose -f docker-compose.dev.yml exec vault sh -c \\"
    echo "     \"VAULT_ADDR=http://127.0.0.1:8200 VAULT_TOKEN=$ROOT_TOKEN vault token revoke -self\""
    echo ""
    echo "   ⚠️  After this, CheckTick uses AppRole credentials only."
    echo "   💡 To make admin changes later, unseal Vault and generate a new root token."
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
else
    if [[ "$VAULT_SEALED" == "true" ]]; then
        echo ""
        echo "🔒 Vault is sealed - it needs to be unsealed after restart"
        echo ""
        echo "   To unseal, you need 3 of your 4 unseal keys:"
        echo ""
        echo "   docker compose -f docker-compose.dev.yml exec vault sh"
        echo "   export VAULT_ADDR=http://127.0.0.1:8200"
        echo "   vault operator unseal <key1>"
        echo "   vault operator unseal <key2>"
        echo "   vault operator unseal <key3>"
        echo ""
        echo "   💡 Tip: Keep your unseal keys in a password manager"
        echo "   ⚠️  CheckTick will not be able to decrypt keys until Vault is unsealed"
        echo ""
    else
        echo "✅ Vault is ready and unsealed"
    fi
fi

# ─── SNOMED CT Setup ────────────────────────────────────────────────────────

echo ""
echo "🏥 Checking SNOMED CT setup..."

# Check if TRUD_API_KEY is configured
TRUD_API_KEY_SET=false
if [[ -n "${TRUD_API_KEY}" ]]; then
    TRUD_API_KEY_SET=true
else
    # Try reading from .env file
    if [[ -f ".env" ]] && grep -q "^TRUD_API_KEY=.\+" .env 2>/dev/null; then
        TRUD_API_KEY_SET=true
    fi
fi

# Check if snomed.db exists in the volume (via the web container)
SNOMED_DB_EXISTS=false
if docker compose -f docker-compose.dev.yml exec -T web test -f /app/data/snomed.db 2>/dev/null; then
    SNOMED_DB_EXISTS=true
fi

if [[ "$SNOMED_DB_EXISTS" == "true" ]]; then
    echo "✅ snomed.db found — SNOMED CT features are available"
else
    echo "⚠️  snomed.db not found — SNOMED CT features will be unavailable"
    echo ""

    if [[ "$TRUD_API_KEY_SET" == "false" ]]; then
        echo "   To enable SNOMED CT features:"
        echo ""
        echo "   1️⃣  Add your TRUD API key to .env:"
        echo "       TRUD_API_KEY=<your_key_from_isd.digital.nhs.uk/trud>"
        echo ""
        echo "   2️⃣  Then run:  ./s/dev --init-snomed"
        echo ""
        echo "   💡 TRUD registration: https://isd.digital.nhs.uk/trud"
        echo "      Request access to item 1799 (UK SNOMED CT Monolith)"
    else
        if [[ "$INIT_SNOMED" != "true" ]]; then
            echo "   TRUD_API_KEY is set. To download and build snomed.db, run:"
            echo ""
            echo "   ./s/dev --init-snomed"
            echo ""
            echo "   ⚠️  This downloads ~1.5 GB and takes several minutes."
        fi
    fi
fi

if [[ "$INIT_SNOMED" == "true" ]]; then
    if [[ "$SNOMED_DB_EXISTS" == "true" ]]; then
        echo ""
        echo "ℹ️  snomed.db already exists — skipping download"
        echo "   To force a rebuild, delete /app/data/snomed.db inside the container first:"
        echo "   docker compose -f docker-compose.dev.yml exec web rm /app/data/snomed.db"
        echo "   Then re-run: ./s/dev --init-snomed"
    elif [[ "$TRUD_API_KEY_SET" == "false" ]]; then
        echo ""
        echo "❌ Cannot seed SNOMED CT: TRUD_API_KEY is not set in .env"
        echo "   Register at https://isd.digital.nhs.uk/trud and add your key."
    else
        echo ""
        echo "🌍 Seeding SNOMED CT database from TRUD..."
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "   Downloading the UK Monolith edition (~1.5 GB) and building snomed.db."
        echo "   All files go to the snomed_data volume at /app/data — not the container."
        echo "   This may take 5–15 minutes depending on your connection."
        echo ""

        docker compose -f docker-compose.dev.yml exec -T web \
            sct trud download \
                --edition uk_monolith \
                --download-dir /app/data \
                --pipeline \
                --output /app/data/snomed.db

        echo ""
        echo "   Running seed_snomed_datasets management command..."
        docker compose -f docker-compose.dev.yml exec -T web \
            python manage.py seed_snomed_datasets

        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "✅ SNOMED CT database seeded successfully!"
        echo ""
        echo "   snomed.db is stored in the snomed_data Docker volume."
        echo "   It will persist across container restarts."
        echo "   To update when a new SNOMED release is published, run:"
        echo "   ./s/dev --init-snomed"
        echo ""
        SNOMED_DB_EXISTS=true
    fi
fi

# ─── Final summary ───────────────────────────────────────────────────────────
echo ""
echo "📋 Development environment startup complete"
echo ""
echo "📝 Services:"
echo "   - CheckTick: http://localhost:8000"
echo "   - Vault UI: http://localhost:8200"
echo "   - PostgreSQL: localhost:5432"
echo ""
echo "🔐 Vault Status:"
if [[ "$VAULT_INITIALIZED" != "true" ]]; then
    echo "   ⚠️  Not initialized - run: ./s/dev --init-vault"
elif [[ "$VAULT_SEALED" == "true" ]]; then
    echo "   🔒 Sealed - needs unsealing (see instructions above)"
else
    echo "   ✅ Ready and unsealed"
fi
echo ""
echo "🏥 SNOMED CT Status:"
if [[ "$SNOMED_DB_EXISTS" == "true" ]]; then
    echo "   ✅ snomed.db ready"
elif [[ "$TRUD_API_KEY_SET" == "false" ]]; then
    echo "   ⚠️  Not configured - set TRUD_API_KEY in .env then run: ./s/dev --init-snomed"
else
    echo "   ⚠️  Not seeded - run: ./s/dev --init-snomed"
fi
echo ""
if [[ "$OPEN_VSCODE" != "true" ]]; then
    echo "💡 Tip: Use './s/dev --code' to automatically open VS Code"
fi

# Open VS Code if requested
if [[ "$OPEN_VSCODE" == "true" ]]; then
    echo ""
    echo "📂 Opening VS Code..."
    code .
fi
